// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  ADMIN
  SUPERVISOR
  TECNICO
  VISUALIZADOR
}

enum StatusOS {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECA
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum PrioridadeOS {
  CRITICA
  ALTA
  MEDIA
  BAIXA
}

enum TipoAtividade {
  // OS de manutenção preventiva geral (usa checklist interno)
  MANUTENCAO_PREVENTIVA_GERAL

  // Corretivas / Emergenciais
  FALHA_ENERGIA
  FALHA_BOMBA_CIRCULACAO
  FALHA_VENTILADOR_EXAUSTAO
  FALHA_BOMBA_REPOSICAO
  ALARME_VAZAMENTO
  ALARME_ALTA_TEMPERATURA
  ALARME_ALTA_PRESSAO
  ALARME_BAIXA_PRESSAO
  ALARME_BAIXA_VAZAO
  ALARME_CONDENSACAO
  FALHA_VEDACAO_BOMBA
  FALHA_VENTILADOR_TORRE
  SUBSTITUICAO_VALVULA_EXAUSTAO
  SUBSTITUICAO_VENTILADOR_TORRE
  OUTRO
}

enum StatusChecklistItem {
  PENDENTE
  OK
  NAO_APLICAVEL
  REQUER_ATENCAO
}

// ─── Usuário ─────────────────────────────────────────────────────────────────
model Usuario {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  nome      String
  email     String   @unique
  cargo     Cargo    @default(VISUALIZADOR)
  ativo     Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordensResponsavel OrdemServico[] @relation("Responsavel")
  ordensAberta      OrdemServico[] @relation("AbertoPor")
  comentarios       Comentario[]
  historicoOS       HistoricoOS[]

  @@map("usuarios")
}

// ─── Ordem de Serviço ─────────────────────────────────────────────────────────
model OrdemServico {
  id            String        @id @default(cuid())
  numero        String        @unique
  titulo        String
  descricao     String
  motivoOS      String
  tipoAtividade TipoAtividade
  status        StatusOS      @default(ABERTA)
  prioridade    PrioridadeOS  @default(MEDIA)

  // SLA
  dataEmissaoAxia DateTime
  prazoSLAHoras   Int
  dataLimiteSLA   DateTime
  slaVencido      Boolean  @default(false)

  // Equipamento
  subsistema    String
  componenteTag String?
  containerId   String?

  // Programação
  dataProgramada DateTime?
  dataInicio     DateTime?
  dataConclusao  DateTime?

  // Relações
  responsavelId String?
  responsavel   Usuario?       @relation("Responsavel", fields: [responsavelId], references: [id])
  abertoPorId   String
  abertoPor     Usuario        @relation("AbertoPor", fields: [abertoPorId], references: [id])

  comentarios    Comentario[]
  historicoOS    HistoricoOS[]
  anexos         Anexo[]
  checklistItems ChecklistItemOS[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ordens_servico")
}

// ─── Checklist de preventiva ──────────────────────────────────────────────────
// Gerado automaticamente ao abrir OS de tipo MANUTENCAO_PREVENTIVA_GERAL
model ChecklistItemOS {
  id           String              @id @default(cuid())
  osId         String
  os           OrdemServico        @relation(fields: [osId], references: [id], onDelete: Cascade)

  // itemId referencia CHECKLIST_PREVENTIVA (lib/checklist-preventiva.ts)
  itemId       String              // ex: "P-001"
  descricao    String              // copiado na criação para histórico
  periodicidade String
  subsistema   String
  referencia   String

  status       StatusChecklistItem @default(PENDENTE)
  observacao   String?             // campo livre para o técnico

  // Auditoria
  atualizadoPorId String?
  atualizadoEm    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("checklist_items_os")
}

// ─── Histórico de status ──────────────────────────────────────────────────────
model HistoricoOS {
  id         String       @id @default(cuid())
  osId       String
  os         OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  statusDe   StatusOS?
  statusPara StatusOS
  observacao String?
  usuarioId  String
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt  DateTime     @default(now())

  @@map("historico_os")
}

// ─── Comentários ─────────────────────────────────────────────────────────────
model Comentario {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  texto     String
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("comentarios")
}

// ─── Anexos ───────────────────────────────────────────────────────────────────
model Anexo {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  nome      String
  url       String       // supabase://bucket/path
  tipo      String
  tamanho   Int
  createdAt DateTime     @default(now())

  @@map("anexos")
}
