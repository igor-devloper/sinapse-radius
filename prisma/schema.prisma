// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  ADMIN
  SUPERVISOR
  TECNICO
  VISUALIZADOR
}

enum StatusOS {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECA
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum PrioridadeOS {
  CRITICA
  ALTA
  MEDIA
  BAIXA
}

// ─── Classificação principal da OS ───────────────────────────────────────────
enum TipoOS {
  PREVENTIVA
  CORRETIVA
}

// ─── Subclassificação das preventivas (define quais itens do checklist abrem) ─
enum PeriodicidadePreventiva {
  DIARIA          // Diário / 2× ao dia
  SEMANAL         // Semanal
  MENSAL          // Mensal
  TRIMESTRAL      // Trimestral
  SEMESTRAL       // Semestral
  ANUAL           // Anual
  HORAS_2000      // A cada 2.000 h
  BIENNIAL        // A cada 1-2 anos
}

// ─── Tipos de atividade corretiva ─────────────────────────────────────────────
enum TipoAtividadeCorretiva {
  FALHA_ENERGIA
  FALHA_BOMBA_CIRCULACAO
  FALHA_VENTILADOR_EXAUSTAO
  FALHA_BOMBA_REPOSICAO
  ALARME_VAZAMENTO
  ALARME_ALTA_TEMPERATURA
  ALARME_ALTA_PRESSAO
  ALARME_BAIXA_PRESSAO
  ALARME_BAIXA_VAZAO
  ALARME_CONDENSACAO
  FALHA_VEDACAO_BOMBA
  FALHA_VENTILADOR_TORRE
  SUBSTITUICAO_VALVULA_EXAUSTAO
  SUBSTITUICAO_VENTILADOR_TORRE
  OUTRO
}

enum StatusChecklistItem {
  PENDENTE
  OK
  NAO_APLICAVEL
  REQUER_ATENCAO
}

// ─── Usuário ─────────────────────────────────────────────────────────────────
model Usuario {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  nome      String
  email     String   @unique
  cargo     Cargo    @default(VISUALIZADOR)
  ativo     Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordensResponsavel OrdemServico[] @relation("Responsavel")
  ordensAberta      OrdemServico[] @relation("AbertoPor")
  comentarios       Comentario[]
  historicoOS       HistoricoOS[]

  @@map("usuarios")
}

// ─── Ordem de Serviço ─────────────────────────────────────────────────────────
model OrdemServico {
  id     String @id @default(cuid())
  numero String @unique
  titulo String

  // ── Classificação ──────────────────────────────────────────
  tipoOS                  TipoOS
  // Preventiva: qual periodicidade (define quais itens do checklist são gerados)
  periodicidadePreventiva PeriodicidadePreventiva?
  // Corretiva: qual tipo de falha/ocorrência
  tipoAtividadeCorretiva  TipoAtividadeCorretiva?

  descricao  String
  motivoOS   String
  status     StatusOS     @default(ABERTA)
  prioridade PrioridadeOS @default(MEDIA)

  // ── SLA — SOMENTE CORRETIVAS ───────────────────────────────
  // Para preventivas esses campos ficam null
  dataEmissaoAxia DateTime?
  prazoSLAHoras   Int?
  dataLimiteSLA   DateTime?
  slaVencido      Boolean   @default(false)

  // ── Data de referência do cronograma preventivo ────────────
  // Usada pelo calendário para posicionar no mês correto
  dataProgramada DateTime?

  // Equipamento
  subsistema    String
  componenteTag String?
  containerId   String?

  // Execução
  dataInicio    DateTime?
  dataConclusao DateTime?

  // Relações
  responsavelId String?
  responsavel   Usuario?       @relation("Responsavel", fields: [responsavelId], references: [id])
  abertoPorId   String
  abertoPor     Usuario        @relation("AbertoPor", fields: [abertoPorId], references: [id])

  comentarios    Comentario[]
  historicoOS    HistoricoOS[]
  anexos         Anexo[]
  checklistItems ChecklistItemOS[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ordens_servico")
}

// ─── Checklist de preventiva ──────────────────────────────────────────────────
// Gerado automaticamente ao abrir OS de tipo PREVENTIVA.
// Apenas os itens cuja periodicidade bate com a da OS são inseridos.
model ChecklistItemOS {
  id    String       @id @default(cuid())
  osId  String
  os    OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  // itemId referencia CHECKLIST_PREVENTIVA (lib/checklist-preventiva.ts)
  itemId        String              // ex: "P-001"
  descricao     String              // copiado na criação para histórico
  periodicidade String
  subsistema    String
  referencia    String

  status     StatusChecklistItem @default(PENDENTE)
  observacao String?             // campo livre para o técnico

  // Auditoria
  atualizadoPorId String?
  atualizadoEm    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("checklist_items_os")
}

// ─── Histórico de status ──────────────────────────────────────────────────────
model HistoricoOS {
  id         String       @id @default(cuid())
  osId       String
  os         OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  statusDe   StatusOS?
  statusPara StatusOS
  observacao String?
  usuarioId  String
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt  DateTime     @default(now())

  @@map("historico_os")
}

// ─── Comentários ─────────────────────────────────────────────────────────────
model Comentario {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  texto     String
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("comentarios")
}

// ─── Anexos ───────────────────────────────────────────────────────────────────
model Anexo {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  nome      String
  url       String       // supabase://bucket/path
  tipo      String
  tamanho   Int
  createdAt DateTime     @default(now())

  @@map("anexos")
}
