// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  ADMIN
  SUPERVISOR
  TECNICO
  VISUALIZADOR
}

enum StatusOS {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECA
  PAUSADA
  CONCLUIDA
  CANCELADA
}

enum PrioridadeOS {
  CRITICA
  ALTA
  MEDIA
  BAIXA
}

enum TipoOS {
  PREVENTIVA
  CORRETIVA
}

enum PeriodicidadePreventiva {
  DIARIA
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
  HORAS_2000
  BIENNIAL
}

enum TipoAtividadeCorretiva {
  FALHA_ENERGIA
  FALHA_BOMBA_CIRCULACAO
  FALHA_VENTILADOR_EXAUSTAO
  FALHA_BOMBA_REPOSICAO
  ALARME_VAZAMENTO
  ALARME_ALTA_TEMPERATURA
  ALARME_ALTA_PRESSAO
  ALARME_BAIXA_PRESSAO
  ALARME_BAIXA_VAZAO
  ALARME_CONDENSACAO
  FALHA_VEDACAO_BOMBA
  FALHA_VENTILADOR_TORRE
  SUBSTITUICAO_VALVULA_EXAUSTAO
  SUBSTITUICAO_VENTILADOR_TORRE
  OUTRO
}

enum StatusChecklistItem {
  PENDENTE
  OK
  NAO_APLICAVEL
  REQUER_ATENCAO
}

model Usuario {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  nome      String
  email     String   @unique
  cargo     Cargo    @default(VISUALIZADOR)
  ativo     Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordensResponsavel OrdemServico[] @relation("Responsavel")
  ordensAberta      OrdemServico[] @relation("AbertoPor")
  comentarios       Comentario[]
  historicoOS       HistoricoOS[]

  @@map("usuarios")
}

model OrdemServico {
  id     String @id @default(cuid())
  numero String @unique
  titulo String

  tipoOS                     TipoOS
  periodicidadesSelecionadas String[]                @default([])
  periodicidadePreventiva    PeriodicidadePreventiva?
  tipoAtividadeCorretiva     TipoAtividadeCorretiva?

  descricao  String
  motivoOS   String
  status     StatusOS     @default(ABERTA)
  prioridade PrioridadeOS @default(MEDIA)

  dataEmissaoAxia DateTime?
  prazoSLAHoras   Int?
  dataLimiteSLA   DateTime?
  slaVencido      Boolean   @default(false)

  dataProgramada    DateTime?
  dataFimProgramada DateTime?

  subsistema    String
  componenteTag String?
  containerId   String?

  dataInicio    DateTime?
  dataConclusao DateTime?

  responsavelId String?
  responsavel   Usuario?        @relation("Responsavel", fields: [responsavelId], references: [id])
  abertoPorId   String
  abertoPor     Usuario         @relation("AbertoPor", fields: [abertoPorId], references: [id])

  comentarios    Comentario[]
  historicoOS    HistoricoOS[]
  anexos         Anexo[]
  checklistItems ChecklistItemOS[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ordens_servico")
}

model Asset {
  id        String   @id @default(cuid())
  nome      String
  codigo    String
  fotoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checklistItems         ChecklistItemOS[]
  checklistTemplateLinks AssetChecklistTemplate[]

  @@map("assets")
}

model AssetChecklistTemplate {
  id              String   @id @default(cuid())
  assetId         String
  checklistItemId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, checklistItemId])
  @@index([checklistItemId])
  @@map("asset_checklist_templates")
}

model ChecklistItemOS {
  id    String       @id @default(cuid())
  osId  String
  os    OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  itemId        String
  descricao     String
  periodicidade String
  subsistema    String
  referencia    String

  assetId String?
  asset   Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  status     StatusChecklistItem @default(PENDENTE)
  observacao String?

  atualizadoPorId String?
  atualizadoEm    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@map("checklist_items_os")
}

model HistoricoOS {
  id         String       @id @default(cuid())
  osId       String
  os         OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  statusDe   StatusOS?
  statusPara StatusOS
  observacao String?
  usuarioId  String
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt  DateTime     @default(now())

  @@map("historico_os")
}

model Comentario {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  texto     String
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("comentarios")
}

model Anexo {
  id        String       @id @default(cuid())
  osId      String
  os        OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)
  nome      String
  url       String
  tipo      String
  tamanho   Int
  createdAt DateTime     @default(now())

  @@map("anexos")
}
